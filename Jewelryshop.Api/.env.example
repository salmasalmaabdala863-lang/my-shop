# Railway environment variables (set in Railway dashboard, not in this file)

ConnectionStrings__DefaultConnection=Host=your-host;Database=your-db;Username=your-user;Password=your-password;SSL Mode=Require;Trust Server Certificate=true

Jwt__Issuer=Jewelryshop.Api
Jwt__Audience=Jewelryshop.Client
Jwt__Key=your-long-random-secret-at-least-32-characters

Cors__AllowedOrigins=https://your-app.vercel.app,http://localhost:5173

Cloudinary__CloudName=your_cloud_name
Cloudinary__ApiKey=your_api_key
Cloudinary__ApiSecret=your_api_secret

ASPNETCORE_ENVIRONMENT=Production
